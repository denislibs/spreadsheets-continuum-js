{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["es2022", "dom"],
    "jsx": "react-jsx",
    "jsxImportSource": "@continuum-js/dom",
    "types": ["vite/client"]
  },
  "include": ["src"]
}
